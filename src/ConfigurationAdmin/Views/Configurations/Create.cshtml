@model ConfigurationReader.Models.ConfigurationItem

@{
    ViewData["Title"] = "Create Configuration";
}

<h1>Create Configuration</h1>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Type" class="form-label"></label>
        <select asp-for="Type" class="form-control">
            <option value="string">string</option>
            <option value="int">int</option>
            <option value="double">double</option>
            <option value="bool">bool</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="Value" class="form-label"></label>
        <input asp-for="Value" class="form-control" />
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>

    <div class="mb-3">
        <label asp-for="ApplicationName" class="form-label"></label>
        <input asp-for="ApplicationName" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>